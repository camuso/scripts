#!/bin/bash
#
# input-test-kunit - Run KUnit input_core test suite
#
# Loads the input_test.ko module from the build tree and checks
# KUnit results via debugfs.
#
# Exit codes: 0=pass, 1=fail, 77=skip
#

KERNEL_DIR="${KERNEL_DIR:-}"

fail() { echo "FAIL: $*" >&2; exit 1; }
skip() { echo "SKIP: $*" >&2; exit 77; }

[[ $(id -u) -ne 0 ]] && skip "Must run as root"

# Find input_test module: explicit path, build tree, standalone build dir, or installed
TEST_MODULE="${INPUT_TEST_MODULE:-}"
KUNIT_MODULE=""
if [[ -z "$TEST_MODULE" ]]; then
	if [[ -n "$KERNEL_DIR" && -f "$KERNEL_DIR/drivers/input/tests/input_test.ko" ]]; then
		TEST_MODULE="$KERNEL_DIR/drivers/input/tests/input_test.ko"
		KUNIT_MODULE="$KERNEL_DIR/lib/kunit/kunit.ko"
	elif [[ -n "$KERNEL_DIR" && -f "$KERNEL_DIR/input_test.ko" ]]; then
		TEST_MODULE="$KERNEL_DIR/input_test.ko"
	else
		for ext in ko ko.xz ko.zst; do
			candidate="/lib/modules/$(uname -r)/kernel/drivers/input/tests/input_test.$ext"
			[[ -f "$candidate" ]] && { TEST_MODULE="$candidate"; break; }
		done
	fi
fi

[[ -n "$TEST_MODULE" ]] || skip "input_test module not found (build tree or installed)"

# Ensure kunit is loaded with enable=1 (RHEL disables by default)
if ! lsmod | grep -q '^kunit'; then
	if [[ -n "$KUNIT_MODULE" && -f "$KUNIT_MODULE" ]]; then
		insmod "$KUNIT_MODULE" enable=1 2>/dev/null || true
	else
		modprobe kunit enable=1 2>/dev/null || skip "Cannot load kunit module"
	fi
else
	# Already loaded -- check if enabled
	if grep -q "disabled" /sys/kernel/debug/kunit/*/results 2>/dev/null; then
		rmmod kunit 2>/dev/null
		modprobe kunit enable=1 2>/dev/null || skip "Cannot reload kunit with enable=1"
	fi
fi

# Ensure debugfs is mounted
if ! mountpoint -q /sys/kernel/debug 2>/dev/null; then
	mount -t debugfs debugfs /sys/kernel/debug 2>/dev/null || \
		skip "Cannot mount debugfs"
fi

# Remove any previous instance
rmmod input_test 2>/dev/null

# Load the test module
if [[ "$TEST_MODULE" == /lib/modules/* ]]; then
	modprobe input_test 2>/dev/null || fail "Failed to load input_test module"
else
	insmod "$TEST_MODULE" 2>/dev/null || fail "Failed to load input_test.ko"
fi

# Give KUnit a moment to finish
sleep 1

# Read results
RESULTS_FILE="/sys/kernel/debug/kunit/input_core/results"
if [[ ! -f "$RESULTS_FILE" ]]; then
	rmmod input_test 2>/dev/null
	fail "KUnit results not found at $RESULTS_FILE"
fi

results=$(cat "$RESULTS_FILE")
echo "$results"

# Check for failures
if echo "$results" | grep -q "^not ok"; then
	rmmod input_test 2>/dev/null
	fail "KUnit test case(s) failed"
fi

if ! echo "$results" | grep -q "^ok"; then
	rmmod input_test 2>/dev/null
	fail "No KUnit test results found"
fi

# Count passed tests
passed=$(echo "$results" | grep -c "^    ok")
echo "KUnit: $passed test cases passed"

# Cleanup
rmmod input_test 2>/dev/null

exit 0
