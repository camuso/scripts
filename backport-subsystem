# Phase 2: commit discovery
# ---------------------------------------------------------------------------

def find_divergence_point(rhel_repo, upstream_repo, scope_paths):
    """Scan RHEL commit bodies per scope path for upstream commit references,
    then select the earliest divergence point so no path's pending commits
    are missed.

    Each scope path gets its own 200-commit scan window, preventing a
    heavily-committed path from pushing a lightly-committed path out of
    the search.

    Recognizes these formats in commit messages:
      - 'commit <40-hex>' on its own line (gort format)
      - 'commit <40-hex> upstream'
      - '(cherry picked from commit <40-hex>)'
    """
    header("Phase 2: Finding divergence point")

    def _extract_candidates(text):
        cands = []
        for m in re.finditer(r"commit\s+([0-9a-f]{40})\s+upstream", text):
            cands.append(m.group(1))
        for m in re.finditer(r"cherry picked from commit ([0-9a-f]{40})", text):
            cands.append(m.group(1))
        if not cands:
            for m in re.finditer(r"^commit\s+([0-9a-f]{40})\s*$", text, re.M):
                cands.append(m.group(1))
        return cands

    def _first_valid(candidates):
        for h in candidates:
            rc, _, _ = run_quiet(f"git cat-file -t {h}", cwd=upstream_repo)
            if rc == 0:
                verify = git(f"log --oneline -1 {h}",
                             cwd=upstream_repo, check=False)
                if verify.returncode == 0:
                    return h, verify.stdout.strip()
        return None, None

    per_path = []
    with Spinner("Scanning RHEL history for divergence points ..."):
        for sp in scope_paths:
            r = git(f"log --format='%B' --no-merges -200 -- {sp}",
                    cwd=rhel_repo, check=False)
            if r.returncode != 0 or not r.stdout.strip():
                continue
            cands = _extract_candidates(r.stdout)
            if not cands:
                continue
            h, desc = _first_valid(cands)
            if h:
                per_path.append((h, sp))

    for h, sp in per_path:
        verify = git(f"log --oneline -1 {h}", cwd=upstream_repo, check=False)
        desc = verify.stdout.strip() if verify.returncode == 0 else ""
        info(f"  {sp}: divergence at {h[:12]}")
        if desc:
            info(f"    {desc}")

    if not per_path:
        with Spinner("Scanning RHEL history (unscoped fallback) ..."):
            r = git("log --format='%B' --no-merges -200", cwd=rhel_repo)
            cands = _extract_candidates(r.stdout)
            h, desc = _first_valid(cands)
        if h:
            info(f"Divergence point (unscoped fallback): {h[:12]}")
            info(f"  {desc}")
            return h
        die("Could not find any upstream commit references in RHEL log.\n"
            "       Use --divergence <upstream-hash> to supply one manually.")

    if len(per_path) == 1:
        return per_path[0][0]

    earliest_h, earliest_sp = per_path[0]
    for h, sp in per_path[1:]:
        rc, _, _ = run_quiet(
            f"git merge-base --is-ancestor {h} {earliest_h}",
            cwd=upstream_repo,
        )
        if rc == 0:
            earliest_h, earliest_sp = h, sp

    info(f"Using earliest divergence: {earliest_h[:12]} (from {earliest_sp})")
    return earliest_h


def list_pending_commits(upstream_repo, divergence, scope_paths, rhel_repo):
    """List upstream commits since divergence touching scope_paths,
    excluding those already on RHEL main."""
    info("Listing upstream commits since divergence ...")
    path_args = " ".join(scope_paths)

    r = git(f"log --no-merges --reverse --format='%H' "
            f"{divergence}..HEAD -- {path_args}",
            cwd=upstream_repo)
    all_hashes = [h for h in r.stdout.strip().split("\n") if h]
    info(f"Found {len(all_hashes)} upstream commits in range")

    if not all_hashes:
        return []

    # Collect upstream hashes already referenced in RHEL commit messages.
    # Use --grep to pre-filter so this is fast even on large repos.
    already = set()
    with Spinner("Scanning RHEL history for already-applied commits ..."):
        for grep_pat in ["commit [0-9a-f]", "cherry picked from commit"]:
            r2 = git(f"log --format='%B' --no-merges --extended-regexp "
                     f"--grep='{grep_pat}'",
                     cwd=rhel_repo, check=False)
            if r2.returncode != 0:
                continue
            for m in re.finditer(r"commit\s+([0-9a-f]{40})", r2.stdout):
                already.add(m.group(1))
            for m in re.finditer(r"cherry picked from commit ([0-9a-f]{40})", r2.stdout):
                already.add(m.group(1))

    pending = [h for h in all_hashes if h not in already]
    info(f"After filtering already-downstream: {len(pending)} pending commits")
    return pending

