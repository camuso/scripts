SESSION_FILE = os.path.join(".backport", "session.json")


def _session_path(repo_root):
    return os.path.join(repo_root, SESSION_FILE)


def load_session(repo_root):
    """Load .backport/session.json or return empty dict."""
    path = _session_path(repo_root)
    if not os.path.isfile(path):
        return {}
    with open(path) as f:
        return json.load(f)


def save_session(repo_root, session):
    """Write session file, updating branch/head metadata."""
    branch = git("rev-parse --abbrev-ref HEAD",
                 cwd=repo_root, check=False).stdout.strip()
    head = git("rev-parse HEAD",
               cwd=repo_root, check=False).stdout.strip()
    session["_last_branch"] = branch
    session["_last_head"] = head

    path = _session_path(repo_root)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        json.dump(session, f, indent=2)
        f.write("\n")


def detect_session_boundary(repo_root, session):
    """Return True if this is a new session (at origin or branch changed)."""
    if not session:
        return True
    last_branch = session.get("_last_branch")
    cur_branch = git("rev-parse --abbrev-ref HEAD",
                     cwd=repo_root, check=False).stdout.strip()
    cur_head = git("rev-parse HEAD",
                   cwd=repo_root, check=False).stdout.strip()
    tracking_tip = git("rev-parse @{upstream}",
                       cwd=repo_root, check=False).stdout.strip()

    at_origin = (cur_head == tracking_tip) if tracking_tip else True
    branch_changed = (cur_branch != last_branch) if last_branch else True
    return at_origin or branch_changed


def has_session_cli_args(args):
    """Return True if the user provided session-level args on the CLI."""
    for field in SESSION_FIELDS:
        val = getattr(args, field, None)
        if field == "patchpal" and val:
            return True
        if field in ("extra_paths",) and val:
            return True
        if field in ("only_paths",) and val is not None:
            return True
        if field not in ("patchpal", "extra_paths", "only_paths") and val is not None:
            return True
    return False


def _prompt_field(label, default, required=False):
    """Prompt for a single field value. Returns the new value or default."""
    if default is None or default == "":
        prompt_str = f"    {label}: "
    else:
        prompt_str = f"    {label} [{default}]: "

    while True:
        val = input(prompt_str).strip()
        if val.lower() == "clear":
            return None if not required else default
        if val == "":
            if required and (default is None or default == ""):
                warn(f"    {label} is required. Please enter a value.")
                continue
            return default
        return val


def prompt_session(previous):
    """Interactively prompt for session parameters.

    previous is the old session dict (may be empty for first run).
    Sticky fields carry their values as defaults.
    Returns a new session dict.
    """
    session = {}

    print()
    status("Session setup")
    info("  Enter to keep [default], 'clear' to remove optional fields")
    print()

    info("  Required:")
    for field, label in [
        ("subsystem",        "subsystem"),
        ("rhel",             "rhel"),
        ("upstream_repo",    "upstream-repo"),
        ("upstream_version", "upstream-version"),
        ("signed_off_by",    "signed-off-by"),
    ]:
        default = previous.get(field)
        if field == "rhel" and default is not None:
            default = str(default)
        val = _prompt_field(label, default, required=True)
        session[field] = int(val) if field == "rhel" else val

    print()
    info("  Optional (Enter to keep, 'clear' to remove):")
    for field, label in [
        ("jira",             "jira"),
        ("toolbox",          "toolbox"),
        ("patchpal",         "patchpal"),
        ("conflict_policy",  "conflict-policy"),
        ("build_policy",     "build-policy"),
        ("assisted_by",      "assisted-by"),
        ("only_paths",       "only-paths"),
        ("extra_paths",      "extra-paths"),
    ]:
        default = previous.get(field)
        if field == "patchpal":
            default = "yes" if default else ("no" if default is not None else None)
            val = _prompt_field(label, default)
            session[field] = val in ("yes", "y", "true", "1") if val else False
        elif field in ("only_paths", "extra_paths"):
            default = " ".join(default) if default else None
            val = _prompt_field(label, default)
            session[field] = val.split() if val else []
        else:
            val = _prompt_field(label, default)
            session[field] = val

    return session


def apply_session_to_args(args, session):
    """Copy session values into args, CLI args take precedence."""
    for field in SESSION_FIELDS:
        cli_val = getattr(args, field, None)
        sess_val = session.get(field)
        if field == "patchpal":
            if not cli_val and sess_val:
                setattr(args, field, sess_val)
        elif field in ("extra_paths",):
            if not cli_val and sess_val:
                setattr(args, field, sess_val)
        elif field == "only_paths":
            if cli_val is None and sess_val is not None:
                setattr(args, field, sess_val)
        else:
            if cli_val is None and sess_val is not None:
                setattr(args, field, sess_val)


def merge_cli_into_session(args, session):
    """Update session dict with any CLI-provided session-level args."""
    for field in SESSION_FIELDS:
        cli_val = getattr(args, field, None)
        if field == "patchpal" and cli_val:
            session[field] = cli_val
        elif field in ("extra_paths",) and cli_val:
            session[field] = cli_val
        elif field == "only_paths" and cli_val is not None:
            session[field] = cli_val
        elif field not in ("patchpal", "extra_paths", "only_paths") and cli_val is not None:
            session[field] = cli_val
    return session


