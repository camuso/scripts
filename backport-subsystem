def print_summary(params, total_evaluated, keep_count, omit_count,
                  clean_count, conflict_count, build_tests,
                  build_fixes, fail_count, patch_count):
    print(f"\n{STA}=== BACKPORT COMPLETE ==={OFF}")
    print(f"  Subsystem:      {params['subsystem']}")
    print(f"  RHEL:           {params['rhel']}")
    print(f"  Branch:         {params['branch']}")
    print(f"  Build policy:   {params['build_policy']}")
    print(f"  Commits evaluated: {total_evaluated}")
    print(f"    KEEP:         {keep_count}")
    print(f"    OMIT:         {omit_count}")
    print(f"    Clean:        {clean_count}")
    print(f"    Conflicts:    {conflict_count} (auto-resolved)")
    print(f"    Build tests:  {build_tests}")
    print(f"    Build fixes:  {build_fixes} (auto-applied)")
    print(f"    Failed:       {fail_count}")
    patches_dir = os.path.join(params['output_dir'], 'patches')
    omitted_path = os.path.join(params['output_dir'], 'Omitted-fixes')
    print(f"  Patches:        {patches_dir} ({patch_count} files)")
    print(f"  Omitted:        {omitted_path} ({omit_count} entries)")

