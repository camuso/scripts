def _show_manpage():
    """Display the man page if possible, otherwise fall back to argparse."""
    manpage = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                           "backport-subsystem.1")
    if os.path.isfile(manpage) and sys.stdout.isatty():
        rc = subprocess.call(["man", manpage])
        if rc == 0:
            sys.exit(0)
    return False


class _ManPageAction(argparse.Action):
    """Custom argparse action: show man page, fall back to --help text."""

    def __init__(self, option_strings, dest=argparse.SUPPRESS,
                 default=argparse.SUPPRESS, **kwargs):
        super().__init__(option_strings, dest=dest, default=default,
                         nargs=0, **kwargs)

    def __call__(self, parser, namespace, values, option_string=None):
        if not _show_manpage():
            parser.print_help()
        sys.exit(0)


