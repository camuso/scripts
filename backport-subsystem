# main
# ---------------------------------------------------------------------------

def main():
    args = parse_args()

    rhel_repo = os.path.abspath(args.rhel_repo)
    upstream_repo = os.path.abspath(args.upstream_repo)

    if not os.path.isdir(os.path.join(rhel_repo, ".git")):
        die(f"Not a git repo: {rhel_repo}")
    if not os.path.isdir(os.path.join(upstream_repo, ".git")):
        die(f"Not a git repo: {upstream_repo}")

    branch = args.branch or os.path.basename(args.subsystem.rstrip("/"))
    output_dir = args.output_dir or os.path.join(
        os.path.dirname(rhel_repo), "backport",
        os.path.basename(args.subsystem.rstrip("/")),
    )
    toolbox_name = f"rhel{args.rhel}"

    scope_paths = discover_scope_paths(
        args.subsystem, upstream_repo, args.extra_paths,
    )
    if not scope_paths:
        die("No valid scope paths found. Check --subsystem and upstream repo.")

    params = {
        "subsystem": args.subsystem,
        "rhel": args.rhel,
        "rhel_repo": rhel_repo,
        "upstream_repo": upstream_repo,
        "upstream_version": args.upstream_version,
        "jira": args.jira,
        "branch": branch,
        "output_dir": output_dir,
        "conflict_policy": args.conflict_policy,
        "build_policy": args.build_policy,
        "scope_paths": scope_paths,
        "dry_run": args.dry_run,
    }

    if not args.yes:
        show_confirmation_menu(params)

    scope_paths = params["scope_paths"]
    conflict_policy = params["conflict_policy"]
    build_policy = params["build_policy"]

    # -- Phase 1 --
    configs_dir = run_dist_configs(rhel_repo, toolbox_name)
    config_map = load_enabled_configs(configs_dir)

    # -- Phase 2 --
    divergence = find_divergence_point(rhel_repo, upstream_repo, scope_paths)
    pending = list_pending_commits(
        upstream_repo, divergence, scope_paths, rhel_repo,
    )
    if not pending:
        die("No pending commits found. Nothing to backport.")

    # -- Phase 3 --
    keep, omit = classify_commits(
        pending, config_map, upstream_repo, rhel_repo, scope_paths,
    )

    if args.dry_run:
        header("Dry run complete")
        info(f"Would cherry-pick {len(keep)} commits, omit {len(omit)}")
        for h, subj, reason in keep:
            print(f"  {STA}KEEP{OFF} {h[:12]} {subj}")
        for h, subj, reason in omit:
            print(f"  {WRN}OMIT{OFF} {h[:12]} {subj}  ({reason})")
        return

    # Save classification lists
    os.makedirs(output_dir, exist_ok=True)
    with open(os.path.join(output_dir, "keep_commits.txt"), "w") as fh:
        for h, subj, reason in keep:
            fh.write(f"{h} {subj}\n")
    with open(os.path.join(output_dir, "omit_commits.txt"), "w") as fh:
        for h, subj, reason in omit:
            fh.write(f"{h} {subj} | {reason}\n")

    # -- Phase 4: cherry-pick loop --
    header("Phase 4: Cherry-picking")

    # Create or checkout branch
    rc, _, _ = run_quiet(f"git rev-parse --verify {branch}", cwd=rhel_repo)
    if rc == 0:
        git(f"checkout {branch}", cwd=rhel_repo)
        info(f"Checked out existing branch '{branch}'")
    else:
        git(f"checkout -b {branch}", cwd=rhel_repo)
        info(f"Created and checked out branch '{branch}'")

    base_commit = git("rev-parse HEAD", cwd=rhel_repo).stdout.strip()

    # Handle --continue
    start_idx = 0
    if args.resume:
        state = load_state(output_dir)
        if state:
            start_idx = state.get("next_idx", 0)
            base_commit = state.get("base_commit", base_commit)
            info(f"Resuming from commit index {start_idx}")
        else:
            warn("No saved state found, starting from beginning")

    clean_count = 0
    conflict_count = 0
    build_tests = 0
    build_fixes = 0
    fail_count = 0

    for idx in range(start_idx, len(keep)):
        h, subj, _ = keep[idx]
        num = f"[{idx + 1}/{len(keep)}]"
        info(f"{num} {h[:12]} {subj}")

        ok, notes = cherry_pick_commit(
            h, upstream_repo, rhel_repo, scope_paths,
            conflict_policy, build_policy, toolbox_name,
            args.subsystem, params["jira"], params["upstream_version"],
            args.rhel, omit, output_dir, idx, len(keep),
        )

        if not ok:
            fail_count += 1
            save_state(output_dir, {
                "next_idx": idx,
                "base_commit": base_commit,
            })
            sys.exit(1)

        if notes:
            conflict_count += 1
        else:
            clean_count += 1

        should_build = (
            (build_policy == "every") or
            (build_policy == "conflict" and notes)
        )
        if should_build:
            build_tests += 1

        save_state(output_dir, {
            "next_idx": idx + 1,
            "base_commit": base_commit,
        })
        status(f"  applied {'(with conflicts)' if notes else '(clean)'}")

    # -- Phase 5 --
    patch_count = generate_output(rhel_repo, output_dir, base_commit, omit)

    # -- Phase 6 --
    print_summary(
        params,
        total_evaluated=len(pending),
        keep_count=len(keep),
        omit_count=len(omit),
        clean_count=clean_count,
        conflict_count=conflict_count,
        build_tests=build_tests,
        build_fixes=build_fixes,
        fail_count=fail_count,
        patch_count=patch_count,
    )


if __name__ == "__main__":
    main()
