DIST_CONFIGS_STAMP = ".backport-dist-configs-head"


def _find_configs_dir(rhel_repo):
    """Locate the dist-configs output directory."""
    configs_dir = os.path.join(rhel_repo, "configs")
    if not os.path.isdir(configs_dir):
        redhat_configs = os.path.join(rhel_repo, "redhat", "configs")
        if os.path.isdir(redhat_configs):
            configs_dir = redhat_configs
    return configs_dir


def _configs_up_to_date(rhel_repo):
    """Check if dist-configs are current for this HEAD."""
    head = git("rev-parse HEAD", cwd=rhel_repo, check=False).stdout.strip()
    stamp = os.path.join(rhel_repo, DIST_CONFIGS_STAMP)
    if not os.path.isfile(stamp):
        return False, head
    with open(stamp) as fh:
        saved = fh.read().strip()
    if saved != head:
        return False, head
    configs_dir = _find_configs_dir(rhel_repo)
    config_files = glob(os.path.join(configs_dir, "kernel-*.config"))
    if not config_files:
        config_files = glob(os.path.join(configs_dir, "**", "kernel-*.config"),
                            recursive=True)
    if not config_files:
        return False, head
    return True, head


def run_dist_configs(rhel_repo, toolbox_name):
    """Run make dist-configs inside the toolbox, return configs directory."""
    header("Phase 1: Building dist-configs")

    up_to_date, head = _configs_up_to_date(rhel_repo)
    if up_to_date:
        configs_dir = _find_configs_dir(rhel_repo)
        config_files = glob(os.path.join(configs_dir, "kernel-*.config"))
        if not config_files:
            config_files = glob(os.path.join(configs_dir, "**",
                                "kernel-*.config"), recursive=True)
        status(f"dist-configs up to date for {head[:12]}")
        info(f"Found {len(config_files)} config files in {configs_dir}")
        return configs_dir

    with Spinner(f"Running make dist-configs in toolbox '{toolbox_name}' ..."):
        rc, out, err = run_quiet(
            f"toolbox run -c {toolbox_name} make dist-configs",
            cwd=rhel_repo,
        )
    if rc != 0:
        die(f"make dist-configs failed:\n{err}")

    configs_dir = _find_configs_dir(rhel_repo)
    config_files = glob(os.path.join(configs_dir, "kernel-*.config"))
    if not config_files:
        config_files = glob(os.path.join(configs_dir, "**", "kernel-*.config"),
                            recursive=True)
    if not config_files:
        die(f"No kernel-*.config files found under {configs_dir}")

    stamp = os.path.join(rhel_repo, DIST_CONFIGS_STAMP)
    with open(stamp, "w") as fh:
        fh.write(head + "\n")

    info(f"Found {len(config_files)} config files in {configs_dir}")
    return configs_dir


def load_enabled_configs(configs_dir):
    """Parse kernel-*.config files into {CONFIG: set(filenames)} map."""
    config_map = defaultdict(set)
    config_files = glob(os.path.join(configs_dir, "kernel-*.config"))
    if not config_files:
        config_files = glob(os.path.join(configs_dir, "**", "kernel-*.config"),
                            recursive=True)
    for cf in config_files:
        bname = os.path.basename(cf)
        with open(cf) as fh:
            for line in fh:
                m = re.match(r"^(CONFIG_\w+)=[ym]", line)
                if m:
                    config_map[m.group(1)].add(bname)
    info(f"Loaded {len(config_map)} enabled CONFIG options across "
         f"{len(config_files)} arch configs")
    return config_map

