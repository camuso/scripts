def run(cmd, *, cwd=None, capture=True, check=True):
    """Run a shell command, return CompletedProcess."""
    return subprocess.run(
        cmd, shell=True, cwd=cwd,
        encoding="utf-8", errors="replace",
        capture_output=capture, check=check,
    )


def run_quiet(cmd, *, cwd=None):
    """Run a command, return (returncode, stdout, stderr)."""
    r = subprocess.run(
        cmd, shell=True, cwd=cwd,
        encoding="utf-8", errors="replace",
        capture_output=True,
    )
    return r.returncode, r.stdout, r.stderr


def git(cmd, *, cwd=None, check=True):
    """Shorthand for 'git <cmd>' in *cwd*."""
    return run(f"git {cmd}", cwd=cwd, check=check)


def die(msg):
    print(f"{CAU}ERROR:{OFF} {msg}", file=sys.stderr)
    sys.exit(1)


UPSTREAM_REMOTE_NAME = "backport-upstream"


def ensure_upstream_remote(rhel_repo, upstream_repo):
    """Ensure the upstream repo is configured as a remote in the RHEL repo.

    Checks for an existing remote pointing to upstream_repo.  If none
    exists, adds one as 'backport-upstream' and fetches from it.
    Returns the remote name.
    """
    upstream_repo = os.path.realpath(upstream_repo)

    r = git("remote -v", cwd=rhel_repo, check=False)
    for line in r.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split()
        if len(parts) >= 2 and os.path.realpath(parts[1]) == upstream_repo:
            remote_name = parts[0]
            info(f"Upstream remote '{remote_name}' already configured")
            return remote_name

    info(f"Adding upstream remote '{UPSTREAM_REMOTE_NAME}' -> {upstream_repo}")
    git(f"remote add {UPSTREAM_REMOTE_NAME} {upstream_repo}",
        cwd=rhel_repo, check=False)
    with Spinner(f"Fetching from '{UPSTREAM_REMOTE_NAME}' ..."):
        git(f"fetch --no-tags {UPSTREAM_REMOTE_NAME}", cwd=rhel_repo, check=False)
    return UPSTREAM_REMOTE_NAME


def info(msg):
    print(f"  {INF}{msg}{OFF}")


def warn(msg):
    print(f"  {WRN}{msg}{OFF}")


def status(msg):
    print(f"  {STA}{msg}{OFF}")


def header(title):
    print(f"\n{MNU}{SEP}{OFF}")
    print(f"  {BLD}{title}{OFF}")
    print(f"{MNU}{SUB}{OFF}")

