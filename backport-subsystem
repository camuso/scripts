def discover_scope_paths(subsystem, upstream_repo, extra_paths):
    """Derive scope paths from the subsystem and validate against upstream."""
    leaf = os.path.basename(subsystem.rstrip("/"))
    candidates = [
        subsystem.rstrip("/"),
        f"include/linux/{leaf}",
        f"include/uapi/linux/{leaf}",
        f"include/dt-bindings/{leaf}",
        f"Documentation/devicetree/bindings/{leaf}",
        f"Documentation/{leaf}",
    ]
    candidates.extend(extra_paths)

    paths = []
    for p in candidates:
        full = os.path.join(upstream_repo, p)
        if os.path.exists(full):
            paths.append(p)
        else:
            glob_hits = glob(full + "*")
            if glob_hits:
                paths.append(p)
    return paths

