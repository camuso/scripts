# ---------------------------------------------------------------------------

def generate_output(rhel_repo, output_dir, base_commit, omit_list):
    """Generate format-patch output and Omitted-fixes file."""
    header("Phase 5: Generating output")

    patches_dir = os.path.join(output_dir, "patches")
    os.makedirs(patches_dir, exist_ok=True)

    git(f"format-patch -o {patches_dir} {base_commit}..HEAD", cwd=rhel_repo)
    patch_files = sorted(glob(os.path.join(patches_dir, "*.patch")))
    info(f"Generated {len(patch_files)} patch files in {patches_dir}")

    omitted_path = os.path.join(output_dir, "Omitted-fixes")
    with open(omitted_path, "w") as fh:
        fh.write(f"# Omitted upstream commits ({len(omit_list)} entries)\n")
        fh.write(f"# Generated by backport-subsystem\n\n")
        for h, subject, reason in omit_list:
            fh.write(f"{h[:12]} {subject}\n")
            fh.write(f"  Reason: {reason}\n\n")
    info(f"Wrote {omitted_path} ({len(omit_list)} entries)")

    return len(patch_files)

