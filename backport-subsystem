        print(f"{SUB}")
        fields = [
            ("Subsystem", params["subsystem"]),
            ("RHEL version", str(params["rhel"])),
            ("RHEL repo", params["rhel_repo"]),
            ("Upstream repo", params["upstream_repo"]),
            ("Upstream version", params["upstream_version"]),
            ("JIRA", params["jira"]),
            ("Branch", params["branch"]),
            ("Output dir", params["output_dir"]),
            ("Conflict policy", conflict_policy),
            ("Build policy", f"{build_policy}"
             + (" (DEFAULT)" if build_policy == "conflict" else "")),
        ]
        for i, (label, value) in enumerate(fields, 1):
            num = f"{i:>3}"
            print(f"  {MNU}{num}.{OFF} {label:<18s}: {INF}{value}{OFF}")

        print(f"{SUB}")
        print(f"  {BLD}Scope Paths{OFF}")
        print(f"{SUB}")
        for j, sp in enumerate(scope_paths):
            letter = chr(ord("a") + j)
            print(f"  {MNU}  {letter}.{OFF} {INF}{sp}{OFF}")
        print(f"{SUB}")
        print()
        print(f"  {MNU}[s]{OFF} Edit scope paths   "
              f"{MNU}[c]{OFF} Toggle conflict policy")
        print(f"  {MNU}[b]{OFF} Cycle build policy "
              f"{MNU}[g]{OFF} Go / proceed")
        print(f"  {MNU}[q]{OFF} Quit")
        print()

        try:
            choice = input(f"  {BLD}Choice:{OFF} ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)

        if choice in ("g", ""):
            params["scope_paths"] = scope_paths
            params["conflict_policy"] = conflict_policy
            params["build_policy"] = build_policy
            return

        elif choice == "q":
            print("Exiting.")
            sys.exit(0)

        elif choice == "s":
            print(f"\n  Current paths: {', '.join(scope_paths)}")
            raw = input("  Enter new comma-separated paths: ").strip()
            if raw:
                scope_paths = [p.strip() for p in raw.split(",") if p.strip()]
                status("Scope paths updated.")
            else:
                warn("No change (empty input).")

        elif choice == "c":
            idx = CONFLICT_POLICIES.index(conflict_policy)
            conflict_policy = CONFLICT_POLICIES[(idx + 1) % len(CONFLICT_POLICIES)]
            status(f"Conflict policy -> {conflict_policy}")

        elif choice == "b":
            idx = BUILD_POLICIES.index(build_policy)
            build_policy = BUILD_POLICIES[(idx + 1) % len(BUILD_POLICIES)]
            status(f"Build policy -> {build_policy}")

        else:
            warn(f"Unknown choice: {choice}")

