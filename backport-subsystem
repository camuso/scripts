SESSION_FIELDS = [
    "subsystem", "rhel", "upstream_repo", "upstream_version",
    "signed_off_by", "jira", "toolbox", "only_paths", "extra_paths",
    "patchpal", "conflict_policy", "build_policy", "assisted_by",
