# Phase 4: cherry-pick + conflict resolution
# ---------------------------------------------------------------------------

CONFLICT_STRICT = "strict"
CONFLICT_CONTEXT_DRIFT = "context_drift"
CONFLICT_NEW_FILE = "new_file"
CONFLICT_OOS_EXCLUDED = "oos_excluded"


def extract_strict_lines(diff_text, filepath=None):
    """Extract only +/- lines from a unified diff, scoped to a single file
    if filepath is given.  Excludes --- and +++ path headers.
    Matches patbatcmp -s -p behavior."""
    lines = []
    in_file = filepath is None
    for line in diff_text.split("\n"):
        if line.startswith("diff --git "):
            if filepath:
                in_file = filepath in line
            continue
        if not in_file:
            continue
        if line.startswith("--- ") or line.startswith("+++ "):
            continue
        if line.startswith("@@"):
            continue
        if line.startswith("+") or line.startswith("-"):
            lines.append(line)
    return lines


def classify_file_conflict(filepath, commit_hash, rhel_repo, upstream_repo):
    """Classify a resolved in-scope conflict for a single file.

    Returns one of CONFLICT_STRICT, CONFLICT_CONTEXT_DRIFT, or
    CONFLICT_NEW_FILE with a human-readable description string.
    """
    exists_in_head = git(
        f"cat-file -e HEAD:{filepath}", cwd=rhel_repo, check=False
    ).returncode == 0

    if not exists_in_head:
        return CONFLICT_NEW_FILE, (
            f"{filepath}: absent in RHEL base; created with upstream content"
        )

    # Get upstream diff for this file
    us_diff = git(
        f"diff {commit_hash}^..{commit_hash} -- {filepath}",
        cwd=upstream_repo, check=False,
    )
    upstream_lines = extract_strict_lines(us_diff.stdout) if us_diff.returncode == 0 else []

    # Get our staged diff for this file
    our_diff = git(f"diff --cached -- {filepath}", cwd=rhel_repo, check=False)
    our_lines = extract_strict_lines(our_diff.stdout) if our_diff.returncode == 0 else []

    # Compare sorted sets of +/- lines (order-independent, like check_possible_fp)
    if sorted(our_lines) == sorted(upstream_lines):
        return CONFLICT_CONTEXT_DRIFT, (
            f"{filepath}: context drift from intervening upstream "
            f"changes not on RHEL base"
        )

    return CONFLICT_STRICT, (
        f"{filepath}: resolved conflict with upstream version "
        f"(strict +/- differences from upstream patch)"
    )


def validate_patch_vs_upstream(commit_hash, upstream_repo, rhel_repo,
                               scope_paths):
    """Compare the just-committed RHEL patch against upstream.

    Uses patbatcmp -s logic: only +/- lines are compared (paths and
    hunk headers excluded).  Returns a dict of validation results:
      {
        "strict_diffs": [(file, description), ...],
        "context_drift": [(file, description), ...],
        "spurious_deletions": [(file, lines), ...],
      }
    """
    results = {
        "strict_diffs": [],
        "context_drift": [],
        "spurious_deletions": [],
    }

    r = git("diff-tree --no-commit-id --name-only -r HEAD", cwd=rhel_repo,
            check=False)
    if r.returncode != 0:
        return results
    our_files = [f for f in r.stdout.strip().split("\n") if f]

    in_scope_prefixes = tuple(p.rstrip("/") for p in scope_paths)
    in_scope_files = [f for f in our_files if f.startswith(in_scope_prefixes)]

    our_full = git("diff HEAD^..HEAD", cwd=rhel_repo, check=False)
    if our_full.returncode != 0:
        return results

    us_full = git(f"diff {commit_hash}^..{commit_hash}", cwd=upstream_repo,
                  check=False)
    if us_full.returncode != 0:
        return results

    for filepath in in_scope_files:
        our_lines = extract_strict_lines(our_full.stdout, filepath)
        us_lines = extract_strict_lines(us_full.stdout, filepath)

        if not our_lines and not us_lines:
            continue

        if sorted(our_lines) != sorted(us_lines):
            our_set = set(our_lines)
            us_set = set(us_lines)
            extra_in_ours = our_set - us_set
            blank_deletions = [l for l in extra_in_ours if l.rstrip() == "-"]
            if blank_deletions and len(extra_in_ours) == len(blank_deletions):
                results["spurious_deletions"].append((
                    filepath,
                    f"has {len(blank_deletions)} blank-line deletion(s) "
                    f"not in upstream patch"
                ))
            else:
                results["strict_diffs"].append((
                    filepath,
                    f"strict +/- differences from upstream"
                ))
        else:
            if our_lines != us_lines:
                results["context_drift"].append((
                    filepath,
                    f"same changes but different line ordering (context drift)"
                ))

    return results


def detect_spurious_hunks(commit_hash, upstream_repo, rhel_repo, scope_paths):
    """Detect hunks that only delete blank lines not present in upstream.

    After conflict resolution (before commit), compares staged hunks against
    the upstream commit to find spurious blank-line deletions.

    Returns a list of (filepath, hunk_description) for spurious hunks found.
    """
    spurious = []

    us_diff = git(f"diff {commit_hash}^..{commit_hash}", cwd=upstream_repo,
                  check=False)
    if us_diff.returncode != 0:
        return spurious

    our_diff = git("diff --cached", cwd=rhel_repo, check=False)
    if our_diff.returncode != 0:
        return spurious

    in_scope_prefixes = tuple(p.rstrip("/") for p in scope_paths)

    current_file = None
    current_hunk_lines = []
    current_hunk_header = ""

    for line in our_diff.stdout.split("\n"):
        if line.startswith("diff --git "):
            if current_file and current_hunk_lines:
                _check_hunk(current_file, current_hunk_header,
                            current_hunk_lines, us_diff.stdout,
                            in_scope_prefixes, spurious)
            m = re.match(r"diff --git a/(\S+) b/(\S+)", line)
            current_file = m.group(2) if m else None
            current_hunk_lines = []
            current_hunk_header = ""
        elif line.startswith("@@"):
            if current_file and current_hunk_lines:
                _check_hunk(current_file, current_hunk_header,
                            current_hunk_lines, us_diff.stdout,
                            in_scope_prefixes, spurious)
            current_hunk_header = line
            current_hunk_lines = []
        elif current_file:
            if line.startswith("+") or line.startswith("-"):
                current_hunk_lines.append(line)

    if current_file and current_hunk_lines:
        _check_hunk(current_file, current_hunk_header,
                    current_hunk_lines, us_diff.stdout,
                    in_scope_prefixes, spurious)

    return spurious


def _check_hunk(filepath, hunk_header, hunk_lines, upstream_diff_text,
                in_scope_prefixes, spurious_list):
    """Check if a hunk is spurious (blank-line-only deletion not in upstream)."""
    if not filepath.startswith(in_scope_prefixes):
        return

    real_changes = [l for l in hunk_lines
                    if not l.startswith("--- ") and not l.startswith("+++ ")]
    if not real_changes:
        return

    all_blank_deletions = all(
        l.rstrip() == "-" for l in real_changes
    )
    if not all_blank_deletions:
        return

    us_lines = extract_strict_lines(upstream_diff_text, filepath)
    blank_dels_in_upstream = sum(1 for l in us_lines if l.rstrip() == "-")

    if blank_dels_in_upstream == 0:
        spurious_list.append((
            filepath,
            f"hunk at {hunk_header.split('@@')[1].strip() if '@@' in hunk_header else '?'}: "
            f"{len(real_changes)} blank-line deletion(s) not in upstream"
        ))


def _resolve_inscope_patchpal(in_scope_conflicts, rhel_repo):
    """Launch patchpal as git mergetool for in-scope conflicted files.

    Returns a list of conflict note strings.
    """
    notes = []
    for cf in in_scope_conflicts:
        info(f"  Launching patchpal for {cf} ...")
        r = subprocess.run(
            "git "
            "-c mergetool.patchpal.cmd='patchpal -M' "
            "-c mergetool.patchpal.trustExitCode=true "
            "-c merge.tool=patchpal "
            f"mergetool --no-prompt -- {cf}",
            shell=True, cwd=rhel_repo,
        )
        if r.returncode != 0:
            git("cherry-pick --abort", cwd=rhel_repo, check=False)
            die(f"patchpal exited with error for {cf}. "
                "Cherry-pick aborted.")
        still_unmerged = git(
            f"diff --name-only --diff-filter=U -- {cf}",
            cwd=rhel_repo, check=False,
        ).stdout.strip()
        if still_unmerged:
            git("cherry-pick --abort", cwd=rhel_repo, check=False)
            die(f"{cf} still has unresolved conflicts after patchpal. "
                "Cherry-pick aborted.")
        notes.append(f"{cf}: resolved interactively via patchpal")
    return notes


def resolve_conflicts(rhel_repo, scope_paths, conflict_policy, rhel_ver,
                      commit_hash=None, upstream_repo=None,
                      use_patchpal=False):
    """Resolve conflicts in the working tree.

    Returns (notes, oos_count) where notes is a list of conflict note strings
    for in-scope files, and oos_count is the number of out-of-scope files
    that were excluded (conflicted or newly added).
    """
    r = git("diff --name-only --diff-filter=U", cwd=rhel_repo, check=False)
    conflicted = [f for f in r.stdout.strip().split("\n") if f]
    if not conflicted:
        return [], 0

    notes = []
    oos_excluded = []
    in_scope_deferred = []
    in_scope_prefixes = tuple(p.rstrip("/") for p in scope_paths)

    for cf in conflicted:
        if cf == "MAINTAINERS":
            git(f"checkout --ours -- {cf}", cwd=rhel_repo, check=False)
            git(f"add {cf}", cwd=rhel_repo, check=False)
            oos_excluded.append(cf)

        elif not cf.startswith(in_scope_prefixes):
            exists_in_head = git(
                f"cat-file -e HEAD:{cf}", cwd=rhel_repo, check=False
            ).returncode == 0
            if exists_in_head:
                git(f"checkout --ours -- {cf}", cwd=rhel_repo, check=False)
                git(f"add {cf}", cwd=rhel_repo, check=False)
            else:
                git(f"rm -f {cf}", cwd=rhel_repo, check=False)
            oos_excluded.append(cf)

        elif use_patchpal:
            in_scope_deferred.append(cf)

        elif conflict_policy == "theirs":
            rc, _, _ = run_quiet(
                f"git checkout --theirs -- {cf}", cwd=rhel_repo
            )
            if rc != 0:
                rc2, _, _ = run_quiet(f"git rm {cf}", cwd=rhel_repo)
                if rc2 == 0:
                    notes.append(
                        f"{cf}: absent in RHEL-{rhel_ver} base; "
                        f"removed (delete/modify conflict)"
                    )
                else:
                    git(f"checkout --ours -- {cf}", cwd=rhel_repo, check=False)
                    git(f"add {cf}", cwd=rhel_repo, check=False)
                    notes.append(
                        f"{cf}: unresolvable conflict; kept downstream version"
                    )
            else:
                git(f"add {cf}", cwd=rhel_repo, check=False)
                if commit_hash and upstream_repo:
                    ctype, note = classify_file_conflict(
                        cf, commit_hash, rhel_repo, upstream_repo,
                    )
                    notes.append(note)
                else:
                    notes.append(
                        f"{cf}: context drift from intervening upstream "
                        f"changes not on RHEL-{rhel_ver} base"
                    )

        elif conflict_policy == "abort":
            die(f"Conflict in {cf} and --conflict-policy=abort. "
                f"Aborting cherry-pick.")

    if in_scope_deferred:
        patchpal_notes = _resolve_inscope_patchpal(
            in_scope_deferred, rhel_repo,
        )
        notes.extend(patchpal_notes)

    return notes, len(oos_excluded)


def check_duplicate_definitions(rhel_repo):
    """Detect duplicate struct/union/enum definitions in staged header files.

    After conflict resolution, both sides of a conflict can survive --
    e.g. a forward declaration replaced by a full definition while the
    original full definition remains further down.  GCC may accept this
    silently (non-debug) or error under -Werror (debug configs).

    Returns a list of (filepath, type_kind, name, kept_line, removed_lines)
    tuples for any duplicates found and auto-fixed.
    """
    r = git("diff --cached --name-only", cwd=rhel_repo, check=False)
    staged = [f for f in r.stdout.strip().split("\n") if f]
    headers = [f for f in staged if f.endswith(".h")]
    if not headers:
        return []

    defn_re = re.compile(
        r"^(struct|union|enum)\s+(\w+)\s*\{", re.MULTILINE,
    )

    fixes = []
    for hdr in headers:
        fullpath = os.path.join(rhel_repo, hdr)
        if not os.path.isfile(fullpath):
            continue
        with open(fullpath) as fh:
            content = fh.read()
        lines = content.splitlines(keepends=True)

        seen = {}
        dups = []
        for i, line in enumerate(lines):
            m = defn_re.match(line)
            if not m:
                continue
            kind, name = m.group(1), m.group(2)
            key = (kind, name)
            if key in seen:
                dups.append((key, seen[key], i))
            else:
                seen[key] = i

        if not dups:
            continue

        for (kind, name), first_line, dup_line in dups:
            brace_depth = 0
            end_first = first_line
            for j in range(first_line, len(lines)):
                brace_depth += lines[j].count("{") - lines[j].count("}")
                if brace_depth == 0:
                    end_first = j
                    break

            brace_depth = 0
            end_dup = dup_line
            for j in range(dup_line, len(lines)):
                brace_depth += lines[j].count("{") - lines[j].count("}")
                if brace_depth == 0:
                    end_dup = j
                    break

            first_body = "".join(lines[first_line:end_first + 1])
            dup_body = "".join(lines[dup_line:end_dup + 1])

            if first_body.strip() == dup_body.strip():
                del lines[dup_line:end_dup + 1]
                with open(fullpath, "w") as fh:
                    fh.writelines(lines)
                git(f"add {hdr}", cwd=rhel_repo, check=False)
                fixes.append((
                    hdr, kind, name, first_line + 1,
                    list(range(dup_line + 1, end_dup + 2)),
                ))
                warn(
                    f"  Auto-fixed: duplicate {kind} {name} "
                    f"in {hdr} (removed lines "
                    f"{dup_line + 1}-{end_dup + 1}, "
                    f"kept definition at line {first_line + 1})"
                )
            else:
                warn(
                    f"  WARNING: {hdr} has divergent duplicate "
                    f"{kind} {name} at lines {first_line + 1} "
                    f"and {dup_line + 1} -- manual review needed"
                )

    return fixes


def scope_index(rhel_repo, scope_paths):
    """Unstage files outside the scope paths from the index.

    Handles two cases for out-of-scope files:
      1. Modified files that exist in HEAD: restore with checkout HEAD --
      2. Newly added files (not in HEAD): remove with git rm -f
    """
    r = git("diff --cached --name-only", cwd=rhel_repo, check=False)
    staged = [f for f in r.stdout.strip().split("\n") if f]
    in_scope_prefixes = tuple(p.rstrip("/") for p in scope_paths)
    removed = []

    for f in staged:
        if f == "MAINTAINERS" or not f.startswith(in_scope_prefixes):
            exists_in_head = git(
                f"cat-file -e HEAD:{f}", cwd=rhel_repo, check=False
            ).returncode == 0
            if exists_in_head:
                git(f"checkout HEAD -- {f}", cwd=rhel_repo, check=False)
            else:
                git(f"rm -f {f}", cwd=rhel_repo, check=False)
            removed.append(f)

    return removed


def build_test(rhel_repo, toolbox_name, subsystem):
    """Run make M=<subsystem> in the toolbox. Returns (success, output).
    Uses KBUILD_MODPOST_WARN=1 so missing Module.symvers (no prior full
    build) only warns instead of failing the compile check."""
    cmd = (f"toolbox run -c {toolbox_name} "
           f"make -j$(nproc) KBUILD_MODPOST_WARN=1 M={subsystem}")
    rc, out, err = run_quiet(cmd, cwd=rhel_repo)
    combined = out + err
    if rc != 0:
        # Distinguish real compiler errors from modpost-only warnings
        has_compiler_error = bool(
            re.search(r":\d+:\d+: error:", combined)
        )
        if not has_compiler_error:
            return True, combined
    return rc == 0, combined


API_REPLACEMENTS = {
    "kzalloc_obj": ("kzalloc(sizeof({arg}), GFP_KERNEL)",
                     r"kzalloc_obj\(([^)]+)\)"),
    "kmalloc_obj": ("kmalloc(sizeof({arg}), GFP_KERNEL)",
                     r"kmalloc_obj\(([^)]+)\)"),
    "kcalloc_obj": ("kzalloc(sizeof({arg}), GFP_KERNEL)",
                     r"kcalloc_obj\(([^)]+)\)"),
    "krealloc_obj": ("krealloc({arg}, sizeof(*({arg})), GFP_KERNEL)",
                      r"krealloc_obj\(([^)]+)\)"),
}


def try_fix_missing_api(build_output, rhel_repo):
    """If build failed due to a known missing API, fix the source in-place.
    Returns (fixed: bool, notes: list[str])."""
    fixes_applied = []

    for line in build_output.split("\n"):
        m = re.search(r"(\S+\.c):(\d+):\d+: error:.*implicit declaration of "
                      r"function ['\u2018](\w+)['\u2019]", line)
        if not m:
            continue
        filepath, lineno, symbol = m.group(1), int(m.group(2)), m.group(3)
        if symbol not in API_REPLACEMENTS:
            continue

        replacement_tpl, pattern = API_REPLACEMENTS[symbol]
        # filepath from compiler is relative to repo root
        full_path = os.path.join(rhel_repo, filepath)
        if not os.path.isfile(full_path):
            continue

        with open(full_path) as fh:
            content = fh.read()

        def replacer(match):
            arg = match.group(1)
            return replacement_tpl.format(arg=arg)

        new_content, count = re.subn(pattern, replacer, content)
        if count > 0:
            with open(full_path, "w") as fh:
                fh.write(new_content)
            git(f"add {filepath}", cwd=rhel_repo, check=False)
            fixes_applied.append(
                f"{filepath}: replaced {count} {symbol}() call(s) with "
                f"RHEL-compatible equivalent"
            )

    return bool(fixes_applied), fixes_applied


def diagnose_build_failure(build_output, commit_hash, subject,
                           rhel_repo, upstream_repo, scope_paths,
                           toolbox_name, subsystem, omit_list,
                           output_dir, applied_count, total_count):
    """Attempt auto-fix for known build error patterns.
    Returns (fixed: bool, fix_note: str or None)."""

    # Try fixing known missing API calls first
    fixed, fix_notes = try_fix_missing_api(build_output, rhel_repo)
    if fixed:
        info("  Auto-fix applied, rebuilding ...")
        ok, new_output = build_test(rhel_repo, toolbox_name, subsystem)
        if ok:
            return True, "; ".join(fix_notes)
        warn("  Rebuild after auto-fix still fails.")
        build_output = new_output

    # Pattern: undeclared identifier / implicit declaration
    m = re.search(r"error:.*['\u2018](\w+)['\u2019].*undeclared", build_output)
    if not m:
        m = re.search(r"error:.*implicit declaration of function "
                      r"['\u2018](\w+)['\u2019]", build_output)

    if m:
        symbol = m.group(1)
        inc_match = re.search(
            r"(include/\S+\.h).*" + re.escape(symbol),
            git(f"grep -rl '{symbol}' -- include/", cwd=rhel_repo,
                check=False).stdout
        )
        if inc_match:
            pass  # too risky to auto-add includes blindly

    # Pattern: incompatible pointer type for .probe / .probe_new
    if re.search(r"\.probe\b.*incompatible pointer type", build_output):
        pass  # needs manual review

    # Write the failure report
    write_build_failure_report(
        output_dir, commit_hash, subject, build_output,
        rhel_repo, applied_count, total_count, scope_paths,
    )
    return False, None


def write_build_failure_report(output_dir, commit_hash, subject,
                               build_output, rhel_repo,
                               applied_count, total_count, scope_paths):
    """Write comprehensive build failure report."""
    os.makedirs(output_dir, exist_ok=True)
    report_path = os.path.join(output_dir, "build-failure-report.txt")

    r = git(f"diff-tree --no-commit-id --name-only -r {commit_hash}",
            cwd=rhel_repo, check=False)
    files = r.stdout.strip() if r.returncode == 0 else "(unavailable)"

    with open(report_path, "w") as fh:
        fh.write(f"=== BUILD FAILURE REPORT ===\n\n")
        fh.write(f"Commit:  {commit_hash}\n")
        fh.write(f"Subject: {subject}\n\n")
        fh.write(f"Applied: {applied_count} of {total_count} commits\n\n")
        fh.write(f"Files touched by this commit:\n{files}\n\n")
        fh.write(f"Compiler output:\n{SUB}\n{build_output}\n{SUB}\n\n")
        fh.write(f"Scope paths: {', '.join(scope_paths)}\n\n")
        fh.write(f"To resume after manual fix:\n")
        fh.write(f"  backport-subsystem --continue "
                 f"--rhel-repo {rhel_repo} ...\n")

    return report_path


def _consolidate_conflict_notes(notes):
    """Group and consolidate conflict notes for gort formatting.

    When there are more than 3 'new upstream file' entries, group them
    into a single consolidated note to avoid excessively long stanzas.
    """
    new_file_notes = []
    other_notes = []

    for note in notes:
        if "absent in RHEL base" in note or "created with upstream content" in note:
            new_file_notes.append(note)
        else:
            other_notes.append(note)

    if len(new_file_notes) > 3:
        paths = []
        for note in new_file_notes:
            m = re.match(r'^(\S+?):', note)
            if m:
                paths.append(m.group(1))
        consolidated = (
            f"{len(new_file_notes)} files absent in RHEL base; "
            f"created with upstream content: "
            + ", ".join(paths)
        )
        other_notes.append(consolidated)
    else:
        other_notes.extend(new_file_notes)

    return other_notes


def format_gort_message(subject, commit_hash, upstream_repo,
                        jira, upstream_version, conflict_notes,
                        signed_off_by, assisted_by=""):
    """Build a gort-style commit message."""
    r = git(f"log --format='%an <%ae>' -1 {commit_hash}", cwd=upstream_repo)
    author = r.stdout.strip()
    r = git(f"log --format='%ad' --date=format:'%a %b %d %H:%M:%S %Y %z' "
            f"-1 {commit_hash}", cwd=upstream_repo)
    date = r.stdout.strip()
    r = git(f"log --format='%B' -1 {commit_hash}", cwd=upstream_repo)
    body = r.stdout.rstrip()

    indented_body = textwrap.indent(body, "    ")

    lines = [subject, ""]
    lines.append(f"JIRA: {jira}")
    lines.append(f"Upstream status: {upstream_version}")

    if conflict_notes:
        consolidated = _consolidate_conflict_notes(conflict_notes)
        lines.append("")
        lines.append("Conflicts:")
        for note in consolidated:
            prefix = f"  - {note}"
            if len(prefix) <= 80:
                lines.append(prefix)
            else:
                m = re.match(r'^(  - \S+:)\s+(.+)$', prefix)
                if m:
                    lines.append(m.group(1))
                    rest = m.group(2)
                else:
                    m2 = re.match(r'^(  - [^;]+;)\s+(.+)$', prefix)
                    if m2:
                        lines.append(m2.group(1))
                        rest = m2.group(2)
                    else:
                        rest = None
                        for wl in textwrap.wrap(prefix, width=80,
                                                initial_indent="",
                                                subsequent_indent="    ",
                                                break_long_words=False,
                                                break_on_hyphens=False):
                            lines.append(wl)
                if rest:
                    for wl in textwrap.wrap(rest,
                                            width=76,
                                            break_long_words=False,
                                            break_on_hyphens=False):
                        lines.append(f"    {wl}")

    lines.append("")
    lines.append(f"commit {commit_hash}")
    lines.append(f"Author: {author}")
    lines.append(f"Date:   {date}")
    lines.append("")
    lines.append(indented_body)
    lines.append("")
    if assisted_by:
        lines.append(f"Assisted-by: {assisted_by}")
    lines.append(f"Signed-off-by: {signed_off_by}")

    return "\n".join(lines)


def cherry_pick_commit(commit_hash, upstream_repo, rhel_repo, scope_paths,
                       conflict_policy, build_policy, toolbox_name,
                       subsystem, jira, upstream_version, rhel_ver,
                       omit_list, output_dir, applied_count, total_count,
                       signed_off_by, assisted_by="",
                       use_patchpal=False):
    """Cherry-pick a single commit with conflict resolution and optional build.
    Returns (success, conflict_notes)."""

    r = git(f"log --format='%s' -1 {commit_hash}", cwd=upstream_repo)
    subject = r.stdout.strip()

    global _cherrypick_repo
    _cherrypick_repo = rhel_repo

    rc, _, err = run_quiet(
        f"git cherry-pick --no-commit {commit_hash}", cwd=rhel_repo,
    )
    had_conflict = rc != 0

    if had_conflict:
        r_unmerged = git("diff --name-only --diff-filter=U",
                         cwd=rhel_repo, check=False)
        r_staged = git("diff --cached --name-only",
                       cwd=rhel_repo, check=False)
        if not r_unmerged.stdout.strip() and not r_staged.stdout.strip():
            warn(f"  Cherry-pick produced no changes: {err.strip()}")
            die(f"Cherry-pick of {commit_hash[:12]} failed with no "
                f"staged changes.\n"
                "       The commit object may not be reachable from "
                "the RHEL repo.")

    conflict_notes = []
    oos_conflict_count = 0
    if had_conflict:
        conflict_notes, oos_conflict_count = resolve_conflicts(
            rhel_repo, scope_paths, conflict_policy, rhel_ver,
            commit_hash=commit_hash, upstream_repo=upstream_repo,
            use_patchpal=use_patchpal,
        )

    removed = scope_index(rhel_repo, scope_paths)
    total_oos = len(removed) + oos_conflict_count
    if total_oos:
        is_treewide = bool(re.search(r'tree[\s-]?wide', subject, re.I))
        if is_treewide:
            conflict_notes.append(
                f"treewide commit scoped to {subsystem}; "
                f"{total_oos} out-of-scope file(s) excluded"
            )
        else:
            conflict_notes.append(
                f"{total_oos} out-of-scope file(s) excluded"
            )

    # Annotate in-scope new files (not present in HEAD before this commit)
    r = git("diff --cached --name-only --diff-filter=A", cwd=rhel_repo,
            check=False)
    new_files = [f for f in r.stdout.strip().split("\n") if f]
    for nf in new_files:
        conflict_notes.append(f"{nf}: new upstream file, included")

    # Annotate in-scope deleted files
    r = git("diff --cached --name-only --diff-filter=D", cwd=rhel_repo,
            check=False)
    del_files = [f for f in r.stdout.strip().split("\n") if f]
    if del_files:
        n = len(del_files)
        conflict_notes.append(
            f"{n} in-scope file(s) removed per upstream"
        )

    dup_fixes = check_duplicate_definitions(rhel_repo)
    for hdr, kind, name, kept, _ in dup_fixes:
        conflict_notes.append(
            f"{hdr}: removed duplicate {kind} {name} "
            f"definition (artifact of conflict resolution)"
        )

    should_build = (
        (build_policy == "every") or
        (build_policy == "conflict" and had_conflict)
    )

    build_ok = True
    if should_build:
        with Spinner(f"Building {subsystem} ..."):
            build_ok, build_output = build_test(
                rhel_repo, toolbox_name, subsystem,
            )
        if not build_ok:
            warn("  Build FAILED -- attempting diagnosis ...")
            fixed, fix_note = diagnose_build_failure(
                build_output, commit_hash, subject,
                rhel_repo, upstream_repo, scope_paths,
                toolbox_name, subsystem, omit_list,
                output_dir, applied_count, total_count,
            )
            if fixed:
                status(f"  Auto-fixed: {fix_note}")
                conflict_notes.append(fix_note)
            else:
                git("reset --hard HEAD", cwd=rhel_repo, check=False)
                report_path = os.path.join(output_dir,
                                           "build-failure-report.txt")
                print(f"\n{CAU}=== BACKPORT ABORTED ==={OFF}")
                print(f"  Failed at:   {commit_hash[:12]} {subject}")
                print(f"  Build error: {report_path}")
                print(f"  Applied:     {applied_count} of {total_count}")
                print(f"  Resume with: backport-subsystem --continue "
                      f"--rhel-repo {rhel_repo} ...")
                return False, conflict_notes

    # Check for spurious blank-line hunks before commit
    spurious = detect_spurious_hunks(
        commit_hash, upstream_repo, rhel_repo, scope_paths,
    )
    if spurious:
        warn("  Spurious blank-line deletion(s) detected:")
        for filepath, desc in spurious:
            warn(f"    {filepath}: {desc}")

    msg = format_gort_message(
        subject, commit_hash, upstream_repo,
        jira, upstream_version, conflict_notes,
        signed_off_by, assisted_by=assisted_by,
    )
    msg_file = "/tmp/backport_msg.txt"
    with open(msg_file, "w") as fh:
        fh.write(msg)

    git(f"commit --allow-empty --file={msg_file}", cwd=rhel_repo)
    _cherrypick_repo = None

    # Post-commit validation against upstream
    validation = validate_patch_vs_upstream(
        commit_hash, upstream_repo, rhel_repo, scope_paths,
    )
    if validation["strict_diffs"]:
        warn("  Post-commit validation: strict +/- differences found:")
        for filepath, desc in validation["strict_diffs"]:
            warn(f"    {filepath}: {desc}")
    if validation["spurious_deletions"]:
        warn("  Post-commit validation: spurious blank-line deletions:")
        for filepath, desc in validation["spurious_deletions"]:
            warn(f"    {filepath}: {desc}")
    if validation["context_drift"]:
        info("  Post-commit validation: context drift (acceptable):")
        for filepath, desc in validation["context_drift"]:
            info(f"    {filepath}: {desc}")

    return True, conflict_notes

