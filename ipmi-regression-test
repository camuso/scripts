#!/bin/bash
#
# ipmi-regression-test
#
# Runs IPMI regression and functional tests in proper sequence.
# Designed to verify IPMI backports do not break existing functionality.
#
# Author: Claude (Anthropic)
# Prompted-by: Tony Camuso <tcamuso@redhat.com>
#

declare -r VERSION="1.1"
declare -r SCRIPT_NAME="$(basename "$0")"

# Text formatting
declare -r BLD='\e[1m'
declare -r GRN='\e[32m'
declare -r YLW='\e[33m'
declare -r RED='\e[31m'
declare -r OFF='\e[0m'

# Test results
declare -i tests_run=0
declare -i tests_passed=0
declare -i tests_failed=0
declare -a failed_tests=()

# Options
declare -i opt_verbose=0
declare -i opt_loop_count=3
declare opt_logfile=""

usage() {
    cat << USAGE

$SCRIPT_NAME [OPTIONS]

Run IPMI regression and functional tests in sequence.

Options:
    -v          Verbose output
    -l COUNT    Number of ipmiloop iterations (default: $opt_loop_count)
    -o FILE     Write results to log file
    -h          Show this help

Test Sequence:
    1. Sanity check    - Quick module reload (ipmireload)
    2. Functional test - IPMI commands loop (ipmiloop)
    3. Stress test     - Module load/unload cycles (custom)
    4. Message test    - Large message handling (ipmi-big-message)

Author: Claude (Anthropic)
Prompted-by: Tony Camuso <tcamuso@redhat.com>

USAGE
    exit 0
}

log() {
    local msg="$1"
    echo -e "$msg"
    [[ -n "$opt_logfile" ]] && echo -e "$msg" | sed 's/\x1b\[[0-9;]*m//g' >> "$opt_logfile"
}

log_header() {
    local title="$1"
    log ""
    log "${BLD}════════════════════════════════════════════════════════════${OFF}"
    log "${BLD}  $title${OFF}"
    log "${BLD}════════════════════════════════════════════════════════════${OFF}"
}

log_result() {
    local test_name="$1"
    local result="$2"
    
    ((tests_run++))
    if [[ "$result" == "PASS" ]]; then
        ((tests_passed++))
        log "${GRN}✓ PASS:${OFF} $test_name"
    else
        ((tests_failed++))
        failed_tests+=("$test_name")
        log "${RED}✗ FAIL:${OFF} $test_name"
    fi
}

run_test() {
    local name="$1"
    local cmd="$2"
    local start_time end_time elapsed
    
    log ""
    log "${YLW}Running: $name${OFF}"
    log "Command: $cmd"
    log "---"
    
    start_time=$(date +%s)
    
    if ((opt_verbose)); then
        eval "$cmd" 2>&1
    else
        eval "$cmd" > /dev/null 2>&1
    fi
    local exit_code=$?
    
    end_time=$(date +%s)
    elapsed=$((end_time - start_time))
    
    if [[ $exit_code -eq 0 ]]; then
        log_result "$name" "PASS"
    else
        log_result "$name (exit code: $exit_code)" "FAIL"
    fi
    log "Elapsed: ${elapsed}s"
    
    return $exit_code
}

capture_state() {
    log_header "Initial System State"
    log "Kernel: $(uname -r)"
    log "Date: $(date)"
    log ""
    log "Loaded IPMI modules:"
    lsmod | grep ipmi | while read line; do log "  $line"; done
    log ""
    log "IPMI devices:"
    ls -la /dev/ipmi* 2>/dev/null | while read line; do log "  $line"; done
}

test_sanity() {
    log_header "Test 1: Sanity Check (Module Reload)"
    run_test "ipmireload" "/root/bin/ipmireload"
}

test_functional() {
    log_header "Test 2: Functional Test (IPMI Commands)"
    # Note: ipmiloop wants -cN not -c N format
    run_test "ipmiloop ($opt_loop_count iterations)" "/root/bin/ipmiloop -c$opt_loop_count -d1"
}

test_stress() {
    log_header "Test 3: Stress Test (Module Load/Unload Cycles)"
    log "${YLW}This tests the locking changes from the backport.${OFF}"
    log "${YLW}Running 5 cycles of ipmi_si reload...${OFF}"
    
    # Custom stress test that handles module dependencies properly
    local -i cycles=5
    local -i i
    local failed=0
    
    for ((i=1; i<=cycles; i++)); do
        log "Cycle $i/$cycles"
        
        # Unload ipmi_si (main driver) - this is safe even with dependencies
        if ! modprobe -rv ipmi_si 2>&1; then
            log "  Warning: Could not fully unload ipmi_si"
        fi
        sleep 1
        
        # Reload ipmi_si
        if ! modprobe -v ipmi_si 2>&1; then
            log "  Error: Failed to reload ipmi_si"
            failed=1
            break
        fi
        sleep 1
        
        # Verify it's working
        if ! ls /dev/ipmi0 > /dev/null 2>&1; then
            log "  Error: /dev/ipmi0 not present after reload"
            failed=1
            break
        fi
    done
    
    if [[ $failed -eq 0 ]]; then
        log_result "stress test ($cycles cycles)" "PASS"
    else
        log_result "stress test" "FAIL"
    fi
    
    return $failed
}

test_message() {
    log_header "Test 4: Large Message Test"
    # This test passes if the driver successfully sends the message
    # The BMC may return 'Invalid command' which is OK - we're testing the driver
    run_test "ipmi-big-message (132 bytes)" "/root/bin/ipmi-big-message"
}

print_summary() {
    log_header "Test Summary"
    log ""
    log "Tests run:    $tests_run"
    log "${GRN}Tests passed: $tests_passed${OFF}"
    log "${RED}Tests failed: $tests_failed${OFF}"
    
    if ((tests_failed > 0)); then
        log ""
        log "${RED}Failed tests:${OFF}"
        for t in "${failed_tests[@]}"; do
            log "  - $t"
        done
    fi
    
    log ""
    if ((tests_failed == 0)); then
        log "${GRN}════════════════════════════════════════════════════════════${OFF}"
        log "${GRN}  ALL TESTS PASSED${OFF}"
        log "${GRN}════════════════════════════════════════════════════════════${OFF}"
        return 0
    else
        log "${RED}════════════════════════════════════════════════════════════${OFF}"
        log "${RED}  SOME TESTS FAILED${OFF}"
        log "${RED}════════════════════════════════════════════════════════════${OFF}"
        return 1
    fi
}

main() {
    while getopts "vl:o:h" opt; do
        case "$opt" in
            v) opt_verbose=1 ;;
            l) opt_loop_count="$OPTARG" ;;
            o) opt_logfile="$OPTARG" ;;
            h) usage ;;
            *) usage ;;
        esac
    done
    
    [[ -n "$opt_logfile" ]] && : > "$opt_logfile"
    
    log_header "IPMI Regression Test Suite v$VERSION"
    log "Author: Claude (Anthropic)"
    log "Prompted-by: Tony Camuso <tcamuso@redhat.com>"
    
    capture_state
    
    test_sanity
    test_functional
    test_stress
    test_message
    
    print_summary
}

main "$@"
