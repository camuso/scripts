#!/bin/bash

declare script_name="$(basename "$0")"
declare conf_dir="$HOME/.config/rhel-upstream-diff"
declare conf_file="$conf_dir/rhel-upstream-diff.conf"
declare rhel_commit=""
declare upstream_remote=""
declare -i stat_only=0

declare bold=$'\e[1m'
declare yellow=$'\e[1;33m'
declare rst=$'\e[0m'

declare usagestr="$(
cat <<EOF
$script_name [-h|--help|help] [-r <remote-or-path>] [-s|--stat] <rhel-commit>

Extract the upstream commit referenced in a RHEL backport commit
and vimdiff the two patches.

The script searches the RHEL commit message for the upstream hash
using these patterns (in priority order):
  1. 'commit <hash>' on its own line (gort format)
  2. 'commit <hash> upstream'
  3. '(cherry picked from commit <hash>)'

The upstream remote or repo path is saved to:
  $conf_dir/rhel-upstream-diff.conf
so it only needs to be specified once. Use -r to change it.

Arguments:
  rhel-commit            RHEL commit hash (or any git rev)

Options:
  -r, --remote <name>    Upstream remote name or path to a separate
                         upstream repo (saved for future runs)
  -s, --stat             Show diffstat comparison instead of vimdiff
  -h, --help             Show this help message

Examples:
  $script_name -r upstream abc1234
  $script_name abc1234
  $script_name -r /work/upstream/kernel abc1234
  $script_name --stat abc1234

EOF
)"

#===========================
#** usage: print usage text
#*
usage() {
	echo -e "$usagestr"
}

#===========================
#** load_conf: load saved upstream remote from conf file
#*
load_conf() {
	[[ -f "$conf_file" ]] || return 1
	local val
	val=$(grep -m1 '^upstream_remote=' "$conf_file" 2>/dev/null)
	val="${val#upstream_remote=}"
	[[ -n "$val" ]] && { upstream_remote="$val"; return 0; }
	return 1
}

#===========================
#** save_conf: persist upstream remote to conf file
#*
# Arguments
#   $1 - upstream remote name or path
#*
save_conf() {
	local val="$1"

	mkdir -p "$conf_dir"
	echo "upstream_remote=$val" > "$conf_file"
}

#===========================
#** exitme: exit with code and optional message
#*
# Arguments
#   $1 - exit code
#   $2 - optional message
#*
exitme() {
	local -i code="$1"
	local msg="$2"

	((code == 0)) && exit "$code"
	[[ -n "$msg" ]] && echo -e "$msg" >&2
	usage
	exit "$code"
}

#===========================
#** control_c: handle Ctrl-C
#*
control_c() {
	echo -e "\nCtrl-c detected. Exiting."
	exitme 1
}

#===========================
#** extract_upstream_hash: find upstream commit hash in RHEL commit message
#*
# Arguments
#   $1 - RHEL commit hash
# Returns (stdout)
#   upstream commit hash, or empty string if not found
#*
extract_upstream_hash() {
	local rhel="$1"
	local msg
	local hash

	msg="$(git log -1 --format='%B' "$rhel")" || return 1

	# Pattern 1: 'commit <hash>' on its own line (gort format)
	hash=$(echo "$msg" | grep -oP '^\s*commit\s+\K[0-9a-f]{40}(?=\s*$)' | head -1)
	[[ -n "$hash" ]] && { echo "$hash"; return 0; }

	# Pattern 2: 'commit <hash> upstream'
	hash=$(echo "$msg" | grep -oP 'commit\s+\K[0-9a-f]{40}(?=\s+upstream)' | head -1)
	[[ -n "$hash" ]] && { echo "$hash"; return 0; }

	# Pattern 3: '(cherry picked from commit <hash>)'
	hash=$(echo "$msg" | grep -oP 'cherry picked from commit\s+\K[0-9a-f]{40}' | head -1)
	[[ -n "$hash" ]] && { echo "$hash"; return 0; }

	return 1
}

#===========================
#** show_diff: display the two commits side by side in vimdiff
#*
# Arguments
#   $1 - RHEL commit hash
#   $2 - upstream commit hash
#*
show_diff() {
	local rhel="$1"
	local upstream="$2"
	local rhel_patch
	local upstream_patch

	rhel_patch=$(mktemp /tmp/rhel-XXXXXX.patch)
	upstream_patch=$(mktemp /tmp/upstream-XXXXXX.patch)

	git show "$rhel" > "$rhel_patch" 2>/dev/null \
		|| exitme 1 "Failed to generate patch for RHEL commit: $rhel"

	if [[ -n "$upstream_repo_path" ]]; then
		git -C "$upstream_repo_path" show "$upstream" > "$upstream_patch" 2>/dev/null \
			|| exitme 1 "Failed to generate patch for upstream commit: $upstream"
	else
		git show "$upstream" > "$upstream_patch" 2>/dev/null \
			|| exitme 1 "Failed to generate patch for upstream commit: $upstream"
	fi

	if ((stat_only)); then
		echo "=== RHEL commit: $rhel ==="
		git show --stat "$rhel"
		echo ""
		echo "=== Upstream commit: $upstream ==="
		if [[ -n "$upstream_repo_path" ]]; then
			git -C "$upstream_repo_path" show --stat "$upstream"
		else
			git show --stat "$upstream"
		fi
	else
		vimdiff "$rhel_patch" "$upstream_patch"
	fi

	rm -f "$rhel_patch" "$upstream_patch"
}

#===========================
#** main: main program logic
#*
main() {
	trap control_c SIGINT

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help|help)
				usage
				exit 0
				;;
			-r|--remote)
				shift
				upstream_remote="$1"
				;;
			-s|--stat)
				stat_only=1
				;;
			*)
				if [[ -z "$rhel_commit" ]]; then
					rhel_commit="$1"
				else
					exitme 1 "Unexpected argument: $1"
				fi
				;;
		esac
		shift
	done

	if [[ -n "$upstream_remote" ]]; then
		save_conf "$upstream_remote"
	else
		load_conf || exitme 1 \
			"\n${yellow}${bold}No upstream remote configured. Use -r <remote-or-path> to set one.${rst}\n"
	fi

	[[ -z "$rhel_commit" ]] && exitme 1 "Missing RHEL commit hash."

	git rev-parse --verify "$rhel_commit" >/dev/null 2>&1 \
		|| exitme 1 "Invalid git revision: $rhel_commit"

	local rhel_full
	rhel_full=$(git rev-parse "$rhel_commit")

	local upstream_hash
	upstream_hash=$(extract_upstream_hash "$rhel_full") \
		|| exitme 1 "No upstream commit reference found in:\n$(git log -1 --format='%s' "$rhel_full")"

	# Detect whether -r is a repo path or a remote name
	upstream_repo_path=""
	if [[ -d "$upstream_remote/.git" ]] || \
	   git -C "$upstream_remote" rev-parse --git-dir >/dev/null 2>&1; then
		upstream_repo_path="$upstream_remote"
		git -C "$upstream_repo_path" rev-parse --verify "$upstream_hash" >/dev/null 2>&1 \
			|| exitme 1 "Upstream commit $upstream_hash not found in $upstream_repo_path"
	else
		git rev-parse --verify "$upstream_hash" >/dev/null 2>&1 || {
			echo "Upstream commit $upstream_hash not found locally." >&2
			echo "Attempting: git fetch $upstream_remote $upstream_hash" >&2
			git fetch "$upstream_remote" "$upstream_hash" 2>/dev/null \
				|| exitme 1 "Could not fetch upstream commit $upstream_hash from remote '$upstream_remote'.\nEnsure the upstream remote is configured and the commit exists."
		}
	fi

	echo "RHEL commit:     $rhel_full"
	echo "Upstream commit: $upstream_hash"
	echo ""

	show_diff "$rhel_full" "$upstream_hash"
}

main "$@"
